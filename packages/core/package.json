{
  "name": "@deskmate/core",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./channels/slack": { "types": "./dist/channels/slack.d.ts", "default": "./dist/channels/slack.js" },
    "./channels/slack-ambient": { "types": "./dist/channels/slack-ambient.d.ts", "default": "./dist/channels/slack-ambient.js" },
    "./channels/eve": { "types": "./dist/channels/eve.d.ts", "default": "./dist/channels/eve.js" },
    "./channels/deskmate-avatars": { "types": "./dist/channels/deskmate-avatars.d.ts", "default": "./dist/channels/deskmate-avatars.js" },
    "./deskmate-says": { "types": "./dist/deskmate-says.d.ts", "default": "./dist/deskmate-says.js" },
    "./front-desk-instructions": { "types": "./dist/front-desk-instructions.d.ts", "default": "./dist/front-desk-instructions.js" }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mama-sh/deskmate.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').copyFileSync('src/front-desk-instructions.md','dist/front-desk-instructions.md')\"",
    "prepack": "pnpm -w run build:packages",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@vercel/connect": "0.2.2",
    "ai": "^7.0.0",
    "eve": "^0.17.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  }
}
