{
  "name": "deskmate",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "deskmate": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js && rm -rf dist/catalog && mkdir -p dist/catalog && cp -R ../catalog/roles dist/catalog/",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@deskmate/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  }
}
