# ── Model access (pick one) ───────────────────────────────────────────────
# Models resolve through the Vercel AI Gateway. Either set a gateway key:
AI_GATEWAY_API_KEY=
# …or run `vercel link` + `vercel env pull` to get VERCEL_OIDC_TOKEN automatically.

# ── Slack (Vercel Connect) ────────────────────────────────────────────────
# The Connect connector UID you provision for Slack (see README → Slack setup).
SLACK_CONNECTOR=slack/deskmate

# ── Deskmate MCP connections (single-deployment, env-token model) ──────────
# Each deskmate reads from one MCP server. Set the URL + token for the
# deskmates you activate; leave the rest blank. With no URL the connection
# falls back to a placeholder and simply returns no tools at call time.

# product_analyst
MIXPANEL_MCP_URL=
MIXPANEL_MCP_TOKEN=

# devops
SENTRY_MCP_URL=
SENTRY_MCP_TOKEN=

# customer_success
INTERCOM_MCP_URL=
INTERCOM_MCP_TOKEN=

# growth_hacker
POSTHOG_MCP_URL=
POSTHOG_MCP_TOKEN=

# project_manager
LINEAR_MCP_URL=
LINEAR_MCP_TOKEN=
